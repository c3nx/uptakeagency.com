---
import Container from "@/components/ui/Container.astro";
import { t, getLocalizedPath } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-surface-border bg-surface-raised">
  <Container>
    <!-- SEO-rich about + services -->
    <div class="py-8 border-b border-surface-border">
      <div class="flex flex-col gap-6 md:flex-row md:justify-between">
        <div class="max-w-lg">
          <a href={getLocalizedPath("/", locale)} class="flex items-center gap-2 font-mono text-sm text-text-primary mb-3">
            <img src="/favicon.svg" alt="Uptake Agency Logo" class="h-5 w-5" />
            <span class="font-semibold">uptake.agency</span>
          </a>
          <p class="text-sm text-text-secondary leading-relaxed">
            {i18n.footer.about}
          </p>
        </div>
        <div class="flex flex-col gap-4 md:items-end">
          <p class="text-xs text-text-muted">info@uptakeagency.com</p>
          <p class="text-xs text-text-muted">Istanbul, Turkey</p>
        </div>
      </div>
      <p class="mt-4 text-xs text-text-muted">
        {i18n.footer.services_keywords}
      </p>
    </div>

    <!-- Copyright + links -->
    <div class="flex flex-col items-center justify-between gap-4 py-6 md:flex-row">
      <p class="text-sm text-text-muted font-mono">
        <span class="text-text-secondary">&copy; {year}</span> uptake.agency <span class="text-text-muted">// {i18n.footer.rights}</span>
      </p>
      <div class="flex gap-6">
        <a
          href={getLocalizedPath("/privacy-policy", locale)}
          class="text-sm text-text-muted hover:text-text-primary transition-colors"
        >
          {i18n.footer.privacy}
        </a>
        <a
          href={getLocalizedPath("/terms-of-service", locale)}
          class="text-sm text-text-muted hover:text-text-primary transition-colors"
        >
          {i18n.footer.terms}
        </a>
        <a
          href={getLocalizedPath("/data-deletion", locale)}
          class="text-sm text-text-muted hover:text-text-primary transition-colors"
        >
          {i18n.footer.data_deletion}
        </a>
      </div>
    </div>
  </Container>
</footer>
