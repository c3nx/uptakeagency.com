---
import Container from "@/components/ui/Container.astro";
import LanguageSwitcher from "@/components/ui/LanguageSwitcher.astro";
import Button from "@/components/ui/Button.astro";
import { t, getLocalizedPath } from "@/i18n";

interface Props {
  locale: "en" | "tr";
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const i18n = t(locale);

const navItems = [
  { label: i18n.nav.about, path: "/about" },
  { label: i18n.nav.services, path: "/services" },
  { label: i18n.nav.work, path: "/work" },
  { label: i18n.nav.contact, path: "/contact" },
];
---

<header class="fixed top-0 z-50 w-full border-b border-gray-100 bg-white/80 backdrop-blur-lg">
  <Container>
    <nav class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={getLocalizedPath("/", locale)} class="text-lg font-semibold text-gray-900">
        Uptake Agency
      </a>

      <!-- Desktop Nav -->
      <div class="hidden items-center gap-8 md:flex">
        {navItems.map((item) => (
          <a
            href={getLocalizedPath(item.path, locale)}
            class:list={[
              "text-sm font-medium transition-colors",
              currentPath === item.path
                ? "text-gray-900"
                : "text-gray-500 hover:text-gray-900",
            ]}
          >
            {item.label}
          </a>
        ))}
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
        <Button href={`mailto:info@uptakeagency.com`} size="sm">
          {i18n.contact.cta}
        </Button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="flex items-center md:hidden"
        aria-label="Toggle menu"
        type="button"
      >
        <svg class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </nav>
  </Container>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white md:hidden">
    <Container>
      <div class="flex flex-col gap-4 py-6">
        {navItems.map((item) => (
          <a
            href={getLocalizedPath(item.path, locale)}
            class="text-base font-medium text-gray-700 hover:text-gray-900"
          >
            {item.label}
          </a>
        ))}
        <div class="flex items-center gap-4 border-t border-gray-100 pt-4">
          <LanguageSwitcher locale={locale} currentPath={currentPath} />
          <Button href={`mailto:info@uptakeagency.com`} size="sm">
            {i18n.contact.cta}
          </Button>
        </div>
      </div>
    </Container>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
