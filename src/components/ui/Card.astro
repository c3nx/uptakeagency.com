---
interface Props {
  class?: string;
  href?: string;
}

const { class: className = "", href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group rounded-2xl border border-gray-100 bg-white p-6 transition-all duration-200",
    href && "hover:border-gray-200 hover:shadow-lg",
    className,
  ]}
>
  <slot />
</Tag>
