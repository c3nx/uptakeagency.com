---
interface Props {
  class?: string;
  href?: string;
}

const { class: className = "", href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group rounded-xl border border-surface-border bg-surface-raised p-6 transition-all duration-200",
    href && "hover:border-surface-border-hover hover:bg-surface-overlay",
    className,
  ]}
>
  <slot />
</Tag>
