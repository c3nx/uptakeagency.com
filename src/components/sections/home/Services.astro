---
import Container from "@/components/ui/Container.astro";
import { t } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);

const services = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: i18n.services.ai_consulting.title,
    description: i18n.services.ai_consulting.description,
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
    title: i18n.services.custom_software.title,
    description: i18n.services.custom_software.description,
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m6.894 5.785l-1.149-.964M6.256 7.178l-1.15-.964m15.352 8.864l-1.41-.513M4.954 9.435l-1.41-.514M12.002 12l-3.75 6.495" /></svg>`,
    title: i18n.services.automation.title,
    description: i18n.services.automation.description,
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>`,
    title: i18n.services.infrastructure.title,
    description: i18n.services.infrastructure.description,
  },
];
---

<section class="py-section-mobile lg:py-section">
  <Container>
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-headline font-bold tracking-tight text-gray-900 sm:text-4xl">
        {i18n.services.title}
      </h2>
      <p class="mt-4 text-lg text-gray-500">
        {i18n.services.subtitle}
      </p>
    </div>

    <!-- Services grid -->
    <div class="mt-16 grid gap-8 sm:grid-cols-2">
      {services.map((service, i) => (
        <div
          class="group relative rounded-2xl border border-gray-100 bg-white p-8 transition-all duration-300 hover:border-gray-200 hover:shadow-xl hover:shadow-gray-100/50"
        >
          <!-- Icon -->
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gray-900 text-white">
            <Fragment set:html={service.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-semibold text-gray-900">
            {service.title}
          </h3>
          <p class="mt-3 text-gray-500 leading-relaxed">
            {service.description}
          </p>

          <!-- Hover accent line -->
          <div class="absolute bottom-0 left-8 right-8 h-[2px] origin-left scale-x-0 bg-brand-300 transition-transform duration-300 group-hover:scale-x-100"></div>
        </div>
      ))}
    </div>
  </Container>
</section>
