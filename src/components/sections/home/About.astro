---
import Container from "@/components/ui/Container.astro";
import { t } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);

const stats = [
  { value: "15+", label: locale === "en" ? "Years Experience" : "Yil Deneyim" },
  { value: "$2M+", label: locale === "en" ? "Revenue Generated" : "Uretilen Gelir" },
  { value: "4", label: locale === "en" ? "Enterprise Partners" : "Kurumsal Ortak" },
];

const timeline = [
  { year: "2009", label: locale === "en" ? "IT Infrastructure" : "BT Altyapi" },
  { year: "2014", label: locale === "en" ? "Gaming Industry" : "Oyun Sektoru" },
  { year: "2018", label: locale === "en" ? "Enterprise Partners" : "Kurumsal Ortaklar" },
  { year: "2022", label: locale === "en" ? "AI Pivot" : "YZ Donusumu" },
  { year: "2024", label: locale === "en" ? "Uptake Agency" : "Uptake Agency" },
];
---

<section class="py-section-mobile lg:py-section">
  <Container>
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
      <!-- Content -->
      <div>
        <p class="font-mono text-sm text-brand-400 mb-4">// {locale === "en" ? "about" : "hakkimizda"}</p>
        <h2 class="text-headline font-bold tracking-tight text-text-primary sm:text-4xl">
          {i18n.about.founder_title}
        </h2>
        <p class="mt-6 text-lg text-text-secondary leading-relaxed">
          {i18n.about.founder_bio}
        </p>

        <!-- Stats -->
        <div class="mt-10 grid grid-cols-3 gap-4">
          {stats.map((stat) => (
            <div class="text-center glass-card p-4">
              <div class="font-mono text-2xl font-bold text-brand-400">
                {stat.value}
              </div>
              <div class="mt-1 text-xs text-text-muted uppercase tracking-wider">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Terminal career timeline -->
      <div class="terminal-window">
        <div class="terminal-dots"></div>
        <div class="p-6 font-mono text-sm">
          <p class="text-text-muted mb-4">
            <span class="text-brand-400">$</span> git log --oneline --author="cengiz"
          </p>
          <div class="space-y-3">
            {timeline.map((item) => (
              <div class="flex items-center gap-3">
                <span class="text-brand-400 font-semibold">{item.year}</span>
                <span class="text-surface-border">---</span>
                <span class="text-text-secondary">{item.label}</span>
              </div>
            ))}
          </div>
          <div class="mt-6 pt-4 border-t border-surface-border">
            <p class="text-text-muted">
              <span class="text-green-400">Cengiz Selcuk</span>
              <span class="text-text-muted"> // Founder & CTO</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
