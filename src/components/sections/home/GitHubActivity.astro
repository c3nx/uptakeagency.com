---
import Container from "@/components/ui/Container.astro";
import { t } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);

// Fetch contribution data via GitHub GraphQL API (public profile stats)
// This shows ALL contributions including private repos (if user has enabled it in GitHub settings)
interface GitHubStats {
  publicRepos: number;
  followers: number;
  totalStars: number;
}

interface RecentRepo {
  name: string;
  description: string | null;
  language: string | null;
  stars: number;
  url: string;
  updatedAt: string;
}

let stats: GitHubStats = { publicRepos: 0, followers: 0, totalStars: 0 };
let recentRepos: RecentRepo[] = [];
let fetchFailed = false;

try {
  // Fetch user profile + recent public repos
  const [userRes, reposRes] = await Promise.all([
    fetch("https://api.github.com/users/c3nx", {
      headers: { "User-Agent": "uptakeagency.com" },
    }),
    fetch("https://api.github.com/users/c3nx/repos?sort=updated&per_page=5&type=owner", {
      headers: { "User-Agent": "uptakeagency.com" },
    }),
  ]);

  if (userRes.ok && reposRes.ok) {
    const user = await userRes.json();
    const repos = await reposRes.json();

    stats = {
      publicRepos: user.public_repos ?? 0,
      followers: user.followers ?? 0,
      totalStars: repos.reduce((sum: number, r: any) => sum + (r.stargazers_count ?? 0), 0),
    };

    recentRepos = repos.slice(0, 4).map((r: any) => ({
      name: r.name,
      description: r.description,
      language: r.language,
      stars: r.stargazers_count ?? 0,
      url: r.html_url,
      updatedAt: r.updated_at,
    }));
  } else {
    fetchFailed = true;
  }
} catch {
  fetchFailed = true;
}

function formatTimeAgo(dateStr: string, loc: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const hours = Math.floor(diff / 3600000);
  const days = Math.floor(diff / 86400000);

  if (loc === "tr") {
    if (days > 0) return `${days} gun once`;
    if (hours > 0) return `${hours} saat once`;
    return "az once";
  }

  if (days > 0) return `${days}d ago`;
  if (hours > 0) return `${hours}h ago`;
  return "just now";
}

const languageColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f7df1e",
  Python: "#3572A5",
  Rust: "#dea584",
  Swift: "#F05138",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Astro: "#ff5a03",
};

const fallbackMessage =
  locale === "tr"
    ? "Aktivite verileri su anda yuklenemiyor. GitHub profilini ziyaret edin."
    : "Activity data currently unavailable. Visit the GitHub profile.";
---

<section class="py-section-mobile lg:py-section">
  <Container>
    <div class="text-center mb-12">
      <p class="font-mono text-sm text-brand-400 mb-4">// {i18n.github.comment}</p>
      <h2 class="text-headline font-bold tracking-tight text-text-primary sm:text-4xl">
        {i18n.github.title}
      </h2>
    </div>

    <div class="max-w-3xl mx-auto">
      {fetchFailed ? (
        <div class="terminal-window">
          <div class="terminal-dots"></div>
          <div class="p-6 font-mono text-sm">
            <p class="text-text-muted italic">{fallbackMessage}</p>
          </div>
        </div>
      ) : (
        <>
          {/* Stats bar */}
          <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="glass-card p-4 text-center">
              <div class="font-mono text-2xl font-bold text-brand-400">{stats.publicRepos}</div>
              <div class="text-xs text-text-muted uppercase tracking-wider mt-1">
                {locale === "tr" ? "Repo" : "Repos"}
              </div>
            </div>
            <div class="glass-card p-4 text-center">
              <div class="font-mono text-2xl font-bold text-brand-400">{stats.totalStars}</div>
              <div class="text-xs text-text-muted uppercase tracking-wider mt-1">Stars</div>
            </div>
            <div class="glass-card p-4 text-center">
              <div class="font-mono text-2xl font-bold text-brand-400">{stats.followers}</div>
              <div class="text-xs text-text-muted uppercase tracking-wider mt-1">Followers</div>
            </div>
          </div>

          {/* Recent repos */}
          <div class="terminal-window">
            <div class="terminal-dots"></div>
            <div class="p-6 font-mono text-sm">
              <p class="text-text-muted mb-4">
                <span class="text-brand-400">$</span> gh repo list c3nx --sort updated --limit 4
              </p>
              <div class="space-y-3">
                {recentRepos.map((repo) => (
                  <a
                    href={repo.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex flex-wrap items-start gap-x-3 gap-y-1 py-2 border-b border-surface-border last:border-0 hover:text-brand-400 transition-colors group"
                  >
                    <span class="text-brand-400 shrink-0">c3nx/</span>
                    <span class="text-text-primary font-semibold group-hover:text-brand-400">{repo.name}</span>
                    {repo.language && (
                      <span class="flex items-center gap-1 text-xs text-text-muted">
                        <span class="h-2 w-2 rounded-full" style={`background:${languageColors[repo.language] || '#666'}`}></span>
                        {repo.language}
                      </span>
                    )}
                    {repo.stars > 0 && (
                      <span class="text-xs text-text-muted">★ {repo.stars}</span>
                    )}
                    <span class="text-text-muted text-xs ml-auto shrink-0">
                      {formatTimeAgo(repo.updatedAt, locale)}
                    </span>
                  </a>
                ))}
              </div>

              <div class="mt-6 pt-4 border-t border-surface-border">
                <a
                  href="https://github.com/c3nx"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                  </svg>
                  {i18n.github.view_profile} &rarr;
                </a>
              </div>
            </div>
          </div>
        </>
      )}
    </div>
  </Container>
</section>
