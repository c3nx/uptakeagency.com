---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { t, getLocalizedPath } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section class="relative overflow-hidden bg-white">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(142,214,240,0.15),transparent)]"></div>

  <Container class="relative">
    <div class="flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center py-20 text-center">
      <!-- Eyebrow -->
      <div class="animate-fade-in mb-6">
        <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-1.5 text-xs font-medium text-gray-600 shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span>
          {locale === "en" ? "Technology Consulting & AI" : "Teknoloji Danismanlik & Yapay Zeka"}
        </span>
      </div>

      <!-- Main heading -->
      <h1 class="animate-slide-up max-w-4xl text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-display">
        {i18n.hero.title}
      </h1>

      <!-- Subtitle -->
      <p class="animate-slide-up mt-6 max-w-2xl text-lg text-gray-500 sm:text-xl" style="animation-delay: 0.1s;">
        {i18n.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="animate-slide-up mt-10 flex flex-col gap-4 sm:flex-row" style="animation-delay: 0.2s;">
        <Button href={getLocalizedPath("/work", locale)} size="lg">
          {i18n.hero.cta_primary}
          <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </Button>
        <Button href={getLocalizedPath("/contact", locale)} variant="secondary" size="lg">
          {i18n.hero.cta_secondary}
        </Button>
      </div>

      <!-- Scroll indicator -->
      <div class="animate-fade-in absolute bottom-8 left-1/2 -translate-x-1/2" style="animation-delay: 0.6s;">
        <div class="flex flex-col items-center gap-2">
          <div class="h-8 w-[1px] bg-gradient-to-b from-transparent to-gray-300"></div>
        </div>
      </div>
    </div>
  </Container>
</section>
