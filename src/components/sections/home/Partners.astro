---
import Container from "@/components/ui/Container.astro";
import { t } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);

const partners = [
  { name: "Intel", logo: "/images/partners/intel.svg" },
  { name: "NVIDIA", logo: "/images/partners/nvidia.svg" },
  { name: "MSI", logo: "/images/partners/msi.svg" },
  { name: "Praxilla", logo: "/images/partners/praxilla.svg" },
];
---

<section class="border-y border-surface-border bg-surface-raised py-16">
  <Container>
    <p class="text-center font-mono text-xs text-text-muted uppercase tracking-widest">
      // {i18n.partners.title}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-16 gap-y-8">
      {partners.map((partner) => (
        <div class="group transition-all duration-300 opacity-40 hover:opacity-100">
          <img
            src={partner.logo}
            alt={`${partner.name} logo`}
            class="h-8 w-auto object-contain"
          />
        </div>
      ))}
    </div>
  </Container>
</section>
