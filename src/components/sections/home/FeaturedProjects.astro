---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import { t, getLocalizedPath } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);

const projects = [
  {
    slug: "estanbul-ai-agent",
    title: "Estanbul AI Agent",
    description: locale === "en"
      ? "Multi-channel AI customer service agent handling inquiries across WhatsApp, web chat, and social media for a gaming entertainment company."
      : "Oyun eglence sirketi icin WhatsApp, web sohbet ve sosyal medya uzerinden musterilere hizmet veren cok kanalli yapay zeka ajansi.",
    tags: ["AI", "LLM", "WhatsApp", "Multi-channel"],
    type: locale === "en" ? "Client Work" : "Musteri Projesi",
    metrics: [
      { value: "70%", label: locale === "en" ? "faster response" : "daha hizli yanit" },
      { value: "85%", label: locale === "en" ? "auto-resolved" : "otomatik cozum" },
    ],
  },
  {
    slug: "quill",
    title: "Quill",
    description: locale === "en"
      ? "AI-powered system-wide technical dictionary for macOS and Windows. Built with Swift and Rust/Tauri for native performance."
      : "macOS ve Windows icin yapay zeka destekli sistem genelinde teknik sozluk. Yerel performans icin Swift ve Rust/Tauri ile gelistirildi.",
    tags: ["AI", "Swift", "Rust", "Tauri"],
    github: "https://github.com/nicepkg/quill",
    type: locale === "en" ? "Open Source" : "Acik Kaynak",
  },
  {
    slug: "aru",
    title: "ARU",
    description: locale === "en"
      ? "WhatsApp Business Platform CRM and automation system. Appointment reminders, campaign management, and AI-powered messaging for SMBs."
      : "WhatsApp Business Platform CRM ve otomasyon sistemi. Randevu hatirlatalari, kampanya yonetimi ve KOBIler icin yapay zeka destekli mesajlasma.",
    tags: ["WhatsApp API", "CRM", "AI", "SaaS"],
    type: locale === "en" ? "Client Work" : "Musteri Projesi",
  },
  {
    slug: "quix",
    title: "Quix",
    description: locale === "en"
      ? "Real-time interactive quiz platform with live multiplayer support, WebSocket communication, and a modern monorepo architecture."
      : "Canli cok oyunculu destek, gercek zamanli WebSocket iletisimi ve modern monorepo mimarisi ile interaktif bilgi yarismasi platformu.",
    tags: ["Next.js", "Express.js", "WebSocket", "Real-time"],
    type: locale === "en" ? "Client Work" : "Musteri Projesi",
    metrics: [
      { value: "<100ms", label: locale === "en" ? "response time" : "yanit suresi" },
    ],
  },
  {
    slug: "oembuilder",
    title: "OEMBuilder",
    description: locale === "en"
      ? "B2B PC build visualization service for MSI. Generates photorealistic images of assembled PC builds from selected components using AI."
      : "MSI icin B2B PC yapi gorsellistirme hizmeti. Yapay zeka kullanarak secilen bilesenlerden fotorealistik monte edilmis PC gorselleri uretir.",
    tags: ["AI", "Gemini", "Python", "FastAPI", "MSI"],
    type: locale === "en" ? "Client Work" : "Musteri Projesi",
  },
];
---

<section class="border-y border-surface-border py-section-mobile lg:py-section">
  <Container>
    <!-- Section header -->
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="font-mono text-sm text-brand-400 mb-4">// {locale === "en" ? "production_outcomes" : "uretim_sonuclari"}</p>
        <h2 class="text-headline font-bold tracking-tight text-text-primary sm:text-4xl">
          {i18n.projects.title}
        </h2>
        <p class="mt-4 max-w-xl text-lg text-text-secondary">
          {i18n.projects.subtitle}
        </p>
      </div>
      <Button href={getLocalizedPath("/work", locale)} variant="secondary">
        {i18n.projects.view_all}
        <svg class="ml-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </Button>
    </div>

    <!-- Projects grid -->
    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={getLocalizedPath(`/work/${project.slug}`, locale)}
          class="group glass-card-hover flex flex-col p-6 sm:p-8"
        >
          <!-- Type badge -->
          <div class="mb-4 flex items-center justify-between">
            <Badge>{project.type}</Badge>
            {project.github && (
              <span class="text-text-muted hover:text-text-primary transition-colors">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
              </span>
            )}
          </div>

          <!-- Title -->
          <h3 class="text-xl font-semibold text-text-primary group-hover:text-brand-400 transition-colors">
            {project.title}
          </h3>

          <!-- Description -->
          <p class="mt-3 flex-1 text-text-secondary leading-relaxed">
            {project.description}
          </p>

          <!-- Metrics -->
          {project.metrics && (
            <div class="mt-4 flex gap-6">
              {project.metrics.map((m) => (
                <div class="flex items-baseline gap-2">
                  <span class="font-mono text-lg font-bold text-brand-400">{m.value}</span>
                  <span class="text-xs text-text-muted">{m.label}</span>
                </div>
              ))}
            </div>
          )}

          <!-- Tags -->
          <div class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="rounded-md bg-surface-overlay px-2.5 py-0.5 text-xs font-mono text-text-muted border border-surface-border">
                {tag}
              </span>
            ))}
          </div>

          <!-- Arrow -->
          <div class="mt-5 flex items-center text-sm font-medium text-text-muted group-hover:text-brand-400 transition-colors">
            <span class="font-mono mr-2 text-xs opacity-60">&gt;</span>
            {i18n.projects.view_project}
            <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
