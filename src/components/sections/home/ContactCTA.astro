---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { t } from "@/i18n";

interface Props {
  locale: "en" | "tr";
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section class="relative overflow-hidden py-section-mobile lg:py-section">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_80%_at_50%_100%,rgba(59,130,246,0.08),transparent)]"></div>

  <Container class="relative">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-sm text-brand-400 mb-4">// {locale === "en" ? "initialize_connection" : "baglanti_baslat"}</p>
      <h2 class="text-headline font-bold tracking-tight text-text-primary sm:text-4xl">
        {i18n.contact.title}
      </h2>
      <p class="mt-6 text-lg text-text-secondary">
        {i18n.contact.subtitle}
      </p>

      <!-- Terminal command -->
      <div class="mt-8 inline-flex items-center gap-3 rounded-lg border border-surface-border bg-surface-raised px-6 py-3 font-mono text-sm">
        <span class="text-brand-400">$</span>
        <span class="text-text-muted">curl -X POST uptake.agency/contact</span>
      </div>

      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="mailto:info@uptakeagency.com" size="lg">
          <span class="font-mono text-sm mr-2 opacity-70">$</span>
          {i18n.contact.cta}
        </Button>
      </div>
      <p class="mt-6 text-sm text-text-muted">
        {i18n.contact.email_label}: <a href="mailto:info@uptakeagency.com" class="text-brand-400 hover:text-brand-300 transition-colors font-mono">info@uptakeagency.com</a>
      </p>
      <p class="mt-2 text-xs text-text-muted">
        Istanbul, Turkey | {locale === "en" ? "Serving clients worldwide" : "Dunya genelinde hizmet"}
      </p>
    </div>
  </Container>
</section>
