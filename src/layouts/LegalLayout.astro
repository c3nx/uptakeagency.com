---
import BaseLayout from "./BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import { t, getLocalizedPath } from "@/i18n";

interface Props {
  title: string;
  description: string;
  locale: "en" | "tr";
  canonicalPath: string;
}

const { title, description, locale, canonicalPath } = Astro.props;
const i18n = t(locale);
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={canonicalPath}
>
  <!-- Minimal header for legal pages -->
  <header class="border-b border-gray-100">
    <Container>
      <nav class="flex h-16 items-center justify-between">
        <a href={getLocalizedPath("/", locale)} class="text-lg font-semibold text-gray-900">
          Uptake Agency
        </a>
        <a
          href={getLocalizedPath("/", locale)}
          class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
        >
          &larr; {locale === "tr" ? "Ana Sayfa" : "Home"}
        </a>
      </nav>
    </Container>
  </header>

  <main>
    <Container>
      <article class="prose prose-gray mx-auto max-w-3xl py-12 md:py-20">
        <slot />
      </article>
    </Container>
  </main>

  <!-- Simple footer -->
  <footer class="border-t border-gray-100">
    <Container>
      <div class="flex flex-col items-center justify-between gap-4 py-8 md:flex-row">
        <p class="text-sm text-gray-500">
          &copy; {new Date().getFullYear()} Uptake Agency. {i18n.footer.rights}
        </p>
        <div class="flex gap-6">
          <a
            href={getLocalizedPath("/privacy-policy", locale)}
            class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            {i18n.footer.privacy}
          </a>
          <a
            href={getLocalizedPath("/terms-of-service", locale)}
            class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            {i18n.footer.terms}
          </a>
          <a
            href={getLocalizedPath("/data-deletion", locale)}
            class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            {i18n.footer.data_deletion}
          </a>
        </div>
      </div>
    </Container>
  </footer>
</BaseLayout>
