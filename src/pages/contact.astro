---
import PageLayout from "@/layouts/PageLayout.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { t } from "@/i18n";

const locale = "en";
const i18n = t(locale);
---

<PageLayout
  title="Contact"
  description="Get in touch with Uptake Agency to discuss your next technology or AI project."
  locale={locale}
  canonicalPath="/contact"
>
  <section class="py-section-mobile lg:py-section">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-display font-bold tracking-tight text-gray-900">
          {i18n.contact.page_title}
        </h1>
        <p class="mt-6 text-xl text-gray-500">
          {i18n.contact.page_subtitle}
        </p>

        <div class="mt-12 rounded-2xl border border-gray-200 bg-gray-50 p-8 sm:p-12">
          <div class="mb-8">
            <h2 class="text-xl font-semibold text-gray-900">
              {i18n.contact.email_label}
            </h2>
            <a
              href="mailto:info@uptakeagency.com"
              class="mt-2 inline-block text-2xl font-medium text-brand-600 hover:text-brand-700 transition-colors"
            >
              info@uptakeagency.com
            </a>
          </div>

          <Button href="mailto:info@uptakeagency.com" size="lg">
            {i18n.contact.cta}
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </Button>
        </div>

        <div class="mt-12">
          <h3 class="text-sm font-medium uppercase tracking-widest text-gray-400">
            {locale === "en" ? "Based in" : "Konum"}
          </h3>
          <p class="mt-2 text-gray-600">Istanbul, Turkey</p>
          <p class="mt-1 text-sm text-gray-500">
            {locale === "en"
              ? "Serving clients worldwide"
              : "Dunya genelinde musterilere hizmet veriyoruz"}
          </p>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
