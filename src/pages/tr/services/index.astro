---
import PageLayout from "@/layouts/PageLayout.astro";
import Container from "@/components/ui/Container.astro";
import { getCollection } from "astro:content";
import { t, getLocalizedPath } from "@/i18n";

const locale = "tr";
const i18n = t(locale);

const services = (await getCollection("services"))
  .filter((s) => s.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Hizmetler"
  description="Teknoloji danismanligi ve yapay zeka cozumleri. Yapay zeka entegrasyonundan ozel yazilim gelistirmeye kadar."
  locale={locale}
  canonicalPath="/services"
>
  <section class="py-section-mobile lg:py-section">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-display font-bold tracking-tight text-gray-900">
          {i18n.services.title}
        </h1>
        <p class="mt-6 text-xl text-gray-500">
          {i18n.services.subtitle}
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2">
        {services.map((service) => (
          <a
            href={getLocalizedPath(`/services/${service.slug.replace(`${locale}/`, "")}`, locale)}
            class="group rounded-2xl border border-gray-100 bg-white p-8 transition-all duration-300 hover:border-gray-200 hover:shadow-xl hover:shadow-gray-100/50"
          >
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-brand-700 transition-colors">
              {service.data.title}
            </h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              {service.data.description}
            </p>
            <div class="mt-5 flex items-center text-sm font-medium text-gray-400 group-hover:text-brand-600 transition-colors">
              {i18n.common.learn_more}
              <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
