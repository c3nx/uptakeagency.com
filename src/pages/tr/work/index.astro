---
import PageLayout from "@/layouts/PageLayout.astro";
import Container from "@/components/ui/Container.astro";
import Badge from "@/components/ui/Badge.astro";
import { getCollection } from "astro:content";
import { t, getLocalizedPath } from "@/i18n";

const locale = "tr";
const i18n = t(locale);

const projects = (await getCollection("projects"))
  .filter((p) => p.data.locale === locale)
  .sort((a, b) => a.data.order - b.data.order);

const typeLabels: Record<string, string> = {
  client: "Musteri Projesi",
  "open-source": "Acik Kaynak",
  demo: "Demo",
};
---

<PageLayout
  title="Projeler"
  description="Yapay zeka, otomasyon ve yazilim gelistirme projelerimiz."
  locale={locale}
  canonicalPath="/work"
>
  <section class="py-section-mobile lg:py-section">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-display font-bold tracking-tight text-text-primary">
          {i18n.projects.title}
        </h1>
        <p class="mt-6 text-xl text-text-secondary">
          {i18n.projects.subtitle}
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <a
            href={getLocalizedPath(`/work/${project.slug.replace(`${locale}/`, "")}`, locale)}
            class="group flex flex-col rounded-2xl border border-surface-border bg-surface-raised p-6 transition-all duration-300 hover:border-surface-border-hover"
          >
            <div class="mb-4 flex items-center justify-between">
              <Badge>{typeLabels[project.data.type]}</Badge>
              {project.data.github && (
                <svg class="h-4 w-4 text-text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
              )}
            </div>

            <h3 class="text-lg font-semibold text-text-primary group-hover:text-brand-400 transition-colors">
              {project.data.title}
            </h3>
            <p class="mt-2 flex-1 text-sm text-text-secondary leading-relaxed">
              {project.data.description}
            </p>

            <div class="mt-4 flex flex-wrap gap-1.5">
              {project.data.tags.map((tag: string) => (
                <span class="rounded-md bg-surface-overlay px-2 py-0.5 text-xs text-text-secondary">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>
</PageLayout>
