---
import PageLayout from "@/layouts/PageLayout.astro";
import Container from "@/components/ui/Container.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import { getCollection } from "astro:content";
import { getLocalizedPath } from "@/i18n";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter((p) => p.data.locale === "tr")
    .map((project) => ({
      params: { slug: project.slug.replace("tr/", "") },
      props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const locale = "tr";

const typeLabels: Record<string, string> = {
  client: "Musteri Projesi",
  "open-source": "Acik Kaynak",
  demo: "Demo",
};
---

<PageLayout
  title={project.data.title}
  description={project.data.description}
  locale={locale}
  canonicalPath={`/work/${project.slug.replace("tr/", "")}`}
>
  <section class="py-section-mobile lg:py-section">
    <Container>
      <div class="mx-auto max-w-3xl">
        <a
          href={getLocalizedPath("/work", locale)}
          class="mb-8 inline-flex items-center text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg class="mr-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Tum Projeler
        </a>

        <div class="flex flex-wrap items-center gap-3 mb-4">
          <Badge>{typeLabels[project.data.type]}</Badge>
          {project.data.github && (
            <a
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-full bg-brand-500 px-3 py-1 text-xs font-medium text-white hover:bg-brand-600 transition-colors"
            >
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
              GitHub
            </a>
          )}
        </div>

        <h1 class="text-display font-bold tracking-tight text-text-primary">
          {project.data.title}
        </h1>
        <p class="mt-4 text-xl text-text-secondary">
          {project.data.description}
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {project.data.tags.map((tag: string) => (
            <span class="rounded-md bg-surface-overlay px-3 py-1 text-sm font-medium text-text-secondary">
              {tag}
            </span>
          ))}
        </div>

        <article class="prose prose-gray prose-invert mt-12 max-w-none prose-headings:font-semibold prose-a:text-brand-400">
          <Content />
        </article>

        <div class="mt-16 rounded-2xl border border-surface-border bg-surface-raised p-8 text-center">
          <h3 class="text-xl font-semibold text-text-primary">Benzer bir projeyle mi ilgileniyorsunuz?</h3>
          <p class="mt-2 text-text-secondary">Isletmeniz icin nasil bir seyler gelistirebileceǵimizi konusalim.</p>
          <div class="mt-6">
            <Button href="mailto:info@uptakeagency.com">
              Iletisime Gecin
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>
